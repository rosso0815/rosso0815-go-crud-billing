# shellcheck disable=SC2034

# PGUSER='goapp'

# PGPASSWORD=''

# PGNAME='goapp'

PGDATABASE='goapp'

# PGHOST='/var/run/postgresql'

# PGPORT='5432'

DB_URI="postgresql://$PGUSER:$PGPASSWORD@/$PGNAME?sslmode=disable&client_encoding=UTF8"

WEB_PREFIX="/goapp"

WEB_LISTENER="localhost:3000"

AUTH_ENABLED="false"

GOOSE_DRIVER=postgres

GOOSE_DBSTRING=postgres://$PGUSER@/$PGNAME

GOOSE_MIGRATION_DIR=./db/schema

GOOSE_TABLE=goose_migrations


# shellcheck disable=SC2034

PGUSER='pfistera'

PGPASSWORD=''

PGNAME='pfistera'

PGHOST='localhost'

PGPORT='5432'

DB_URI="postgresql://$PGUSER:$PGPASSWORD@$PGHOST/$PGNAME?sslmode=disable&client_encoding=UTF8"

WEB_PREFIX="/goapp"

WEB_LISTENER="localhost:3000"

AUTH_ENABLED="false"

GOOSE_DRIVER=postgres

GOOSE_DBSTRING=postgres://$PGUSER@$PGHOST:5432/$PGNAME

GOOSE_MIGRATION_DIR=./db/schema

GOOSE_TABLE=goose_migrations

GOBIN=$PWD/bin

PATH=$PWD/bin:$PATH

KUBECONFIG=/var/tmp/k3s.yaml


